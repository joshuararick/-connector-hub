# Copy to .env locally. Never commit .env.
AGENT_MAKER_ENV=development
AGENT_MAKER_APP_SECRET=replace_with_generated_secret
AGENT_MAKER_ENCRYPTION_KEY=replace_with_generated_fernet_key
AGENT_MAKER_SIGNING_KEY=replace_with_generated_signing_key
AGENT_MAKER_STATE_DIR=.data
AGENT_MAKER_REQUIRE_APPROVAL=true

# Provider keys must be created in the provider dashboard, not generated locally.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
